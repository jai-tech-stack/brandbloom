# Database (SQLite for dev; use postgresql:// for production)
DATABASE_URL="file:./dev.db"

# NextAuth — required for auth
NEXTAUTH_SECRET="generate-a-random-string-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Replicate — required for real AI image generation (FLUX Schnell)
REPLICATE_API_TOKEN=""

# Optional — LLM for brand personality/tone (tries OpenAI first, then Anthropic)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Stripe — optional; for "Buy credits"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CREDITS_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Redis (optional — for background workers)
REDIS_URL=""

# Cloudflare R2 (optional — for storing generated images)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="brandbloom-assets"
R2_PUBLIC_URL=""
